rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sites/{document} {
      allow read, write: if true;
    }
    match /deliveries/{document} {
      allow read, write: if true;
    }
    match /erections/{document} {
      allow read, write: if true;
    }
    match /suggestions/{document} {
      allow read, write: if true;
    }
  }
}
